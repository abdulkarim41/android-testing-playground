<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph_main"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.abdulkarim.android_testing_playground.presentation.login.LoginFragment"
        android:label="LoginFragment"
        tools:layout="@layout/fragment_login">

        <action
            android:id="@+id/action_navigate_to_productFragment"
            app:destination="@id/productFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true"/>

    </fragment>


    <fragment
        android:id="@+id/productFragment"
        android:name="com.abdulkarim.android_testing_playground.presentation.product.ProductFragment"
        android:label="ProductFragment"
        tools:layout="@layout/fragment_product">


    </fragment>

</navigation>